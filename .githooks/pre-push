#!/usr/bin/env bash
# Pre-push verify gate — the routine local stand-in for the GitHub-hosted
# `Verify (lint)` and `news-version` workflows, which are TEMPORARILY gated to
# CRAN-submission prep only (workflow_dispatch + release tags 'v*') because
# GitHub-hosted runners are disabled on this account.
#
# This is the LIGHT, deterministic gate — the two cheap checks that catch the
# common mistakes without needing the full Suggests toolchain installed:
#   - news-version.yaml  : top NEWS.md heading vs DESCRIPTION Version
#   - Verify / lint      : lintr::lint_package() (fails on any lint)
#
# The heavyweight correctness checks — `R CMD check`, the cross-platform matrix
# (full-check.yml), and R-hub (rhub.yaml) — are the "remote testing at CRAN
# submission" path: they run on release tags / on demand, and require the full
# Suggests set (covr, goodpractice, DT, visNetwork, ...). Run `R CMD check`
# locally yourself before tagging a release if you want a pre-flight.
#
# Enable once per clone:   git config core.hooksPath .githooks
# Emergency bypass:        SKIP_VERIFY=1 git push
set -euo pipefail

if [ "${SKIP_VERIFY:-}" = "1" ]; then
  echo "pre-push: SKIP_VERIFY=1 set — skipping the verify gate" >&2
  exit 0
fi

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

# 1. NEWS / DESCRIPTION version consistency (mirrors news-version.yaml).
echo "pre-push: NEWS/version consistency ..." >&2
version="$(grep -E '^Version:' DESCRIPTION | head -n1 | sed -E 's/^Version:[[:space:]]*//')"
heading="$(grep -m1 -E '^# ' NEWS.md | sed -E 's/^#[[:space:]]+pagerankr[[:space:]]*//')"
if [ "$heading" != "(development version)" ] && [ "$heading" != "$version" ]; then
  echo "pre-push: top NEWS.md heading ('$heading') is neither '(development version)'" >&2
  echo "          nor the DESCRIPTION Version ('$version'). Update NEWS.md." >&2
  exit 1
fi

# 2. Lint (mirrors the Verify `lint` job; fails on any lint).
echo "pre-push: lintr::lint_package() ..." >&2
Rscript -e 'l <- lintr::lint_package(); if (length(l)) { print(l); quit(status = 1L) }'

echo "pre-push: lint + NEWS checks passed ✓" >&2
