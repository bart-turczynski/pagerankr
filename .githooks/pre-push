#!/usr/bin/env bash
# Pre-push verify gate — the routine local stand-in for the GitHub-hosted
# `Verify` and `news-version` workflows, which are TEMPORARILY gated to
# CRAN-submission prep only (workflow_dispatch + release tags 'v*') because
# GitHub-hosted runners are disabled on this account. This hook runs the same
# checks locally so a tree that would turn those workflows red can't be pushed.
#
# Mirrors:
#   - news-version.yaml : top NEWS.md heading vs DESCRIPTION Version
#   - Verify / lint     : lintr::lint_package() (error on any lint)
#   - Verify / check    : standard R CMD check (--no-manual)
# The strict cross-platform --as-cran pass still lives in full-check.yml (run on
# release tags / on demand at CRAN time).
#
# Enable once per clone:   git config core.hooksPath .githooks
# Emergency bypass:        SKIP_VERIFY=1 git push
set -euo pipefail

if [ "${SKIP_VERIFY:-}" = "1" ]; then
  echo "pre-push: SKIP_VERIFY=1 set — skipping the verify gate" >&2
  exit 0
fi

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

# 1. NEWS / DESCRIPTION version consistency (mirrors news-version.yaml).
echo "pre-push: NEWS/version consistency ..." >&2
version="$(grep -E '^Version:' DESCRIPTION | head -n1 | sed -E 's/^Version:[[:space:]]*//')"
heading="$(grep -m1 -E '^# ' NEWS.md | sed -E 's/^#[[:space:]]+pagerankr[[:space:]]*//')"
if [ "$heading" != "(development version)" ] && [ "$heading" != "$version" ]; then
  echo "pre-push: top NEWS.md heading ('$heading') is neither '(development version)'" >&2
  echo "          nor the DESCRIPTION Version ('$version'). Update NEWS.md." >&2
  exit 1
fi

# 2. Lint (mirrors the Verify `lint` job; fails on any lint).
echo "pre-push: lintr::lint_package() ..." >&2
Rscript -e 'l <- lintr::lint_package(); if (length(l)) { print(l); quit(status = 1L) }'

# 3. R CMD check (mirrors the Verify `check` job: standard --no-manual pass).
#    Prefer rcmdcheck (errors on WARNING, like the r-lib CI action); fall back to
#    base `R CMD build` + `R CMD check` (errors on ERROR only) when it's absent.
#    `_R_CHECK_FORCE_SUGGESTS_=false` so a local clone missing optional Suggests
#    (covr, goodpractice, DT, visNetwork, ...) doesn't fail the gate — CI installs
#    them for the full check; the local gate covers lint + the core check.
echo "pre-push: R CMD check (--no-manual) ..." >&2
export _R_CHECK_FORCE_SUGGESTS_=false
if Rscript -e 'quit(status = as.integer(!requireNamespace("rcmdcheck", quietly = TRUE)))'; then
  Rscript -e 'rcmdcheck::rcmdcheck(args = "--no-manual", error_on = "warning")'
else
  echo "pre-push: rcmdcheck not installed — using base R CMD build + check (errors on ERROR only)" >&2
  R CMD build . --no-build-vignettes >&2
  tarball="$(ls -t pagerankr_*.tar.gz | head -n1)"
  R CMD check "$tarball" --no-manual
  rm -f "$tarball"
fi

echo "pre-push: all checks passed ✓" >&2
