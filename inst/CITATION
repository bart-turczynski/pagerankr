citHeader("To cite the pagerankr package in publications, use:")

year <- sub("-.*", "", meta$Date)
if (!length(year) || is.na(year) || !nzchar(year)) {
  year <- format(Sys.Date(), "%Y")
}
note <- sprintf("R package version %s", meta$Version)

bibentry(
  bibtype = "Manual",
  title   = "{pagerankr}: Modular Toolkit for PageRank Calculation",
  author  = person("Bart", "Turczynski",
                   comment = c(ORCID = "0000-0002-8788-7980")),
  year    = year,
  note    = note,
  url     = "https://github.com/bart-turczynski/pagerankr"
)
